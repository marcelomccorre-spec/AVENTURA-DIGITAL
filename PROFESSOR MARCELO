<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Aventura Digital - Curso gratuito de Computação Básica para Crianças. Aprenda hardware, software, internet e programação de forma divertida!">
    <meta name="keywords" content="computação para crianças, aula de informática, programação kids, tecnologia educação">
    <meta name="author" content="Professor">
    <meta name="theme-color" content="#667eea">
    
    <!-- Open Graph para compartilhamento -->
    <meta property="og:title" content="🚀 Aventura Digital - Computação para Crianças">
    <meta property="og:description" content="Curso interativo e gratuito de computação básica para crianças">
    <meta property="og:type" content="website">
    
    <title>🚀 Aventura Digital | Computação para Crianças</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚀</text></svg>">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary: #FF6B6B;
            --secondary: #4ECDC4;
            --accent: #FFE66D;
            --purple: #9B5DE5;
            --dark: #2C3E50;
            --light: #F7F9FC;
            --success: #2ECC71;
        }
        
        body {
            font-family: 'Nunito', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: var(--dark);
            overflow-x: hidden;
        }
        
        /* Animações */
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-40px) rotate(180deg); }
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }
        
        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes wave {
            0%, 100% { transform: rotate(0deg); }
            25% { transform: rotate(20deg); }
            75% { transform: rotate(-20deg); }
        }
        
        /* Shapes de fundo */
        .floating-shapes {
            position: fixed;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }
        
        .shape {
            position: absolute;
            opacity: 0.15;
            animation: float 25s infinite ease-in-out;
            font-size: 2.5em;
        }
        
        /* Header */
        header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 20px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        
        .header-content {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        h1 {
            font-family: 'Fredoka One', cursive;
            font-size: 2.2em;
            background: linear-gradient(45deg, var(--primary), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: bounce 2s infinite;
            cursor: pointer;
        }
        
        .subtitle {
            color: var(--secondary);
            font-size: 1.1em;
            font-weight: 700;
            margin-top: 5px;
        }
        
        .progress-container {
            width: 100%;
            max-width: 400px;
            margin: 15px auto 0;
        }
        
        .progress-bar {
            width: 100%;
            height: 12px;
            background: #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--secondary), var(--primary));
            width: 0%;
            transition: width 0.5s ease;
            border-radius: 10px;
            position: relative;
            overflow: hidden;
        }
        
        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            animation: shimmer 2s infinite;
        }
        
        .progress-text {
            margin-top: 8px;
            font-size: 0.9em;
            color: var(--purple);
            font-weight: 800;
        }
        
        /* Navegação */
        .quick-nav {
            background: white;
            padding: 15px;
            margin: 20px auto;
            max-width: 1200px;
            border-radius: 50px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
            position: sticky;
            top: 100px;
            z-index: 999;
        }
        
        .nav-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 25px;
            background: var(--light);
            color: var(--dark);
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9em;
        }
        
        .nav-btn:hover, .nav-btn.active {
            background: var(--secondary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(78,205,196,0.4);
        }
        
        /* Container */
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* Módulos */
        .module {
            background: white;
            border-radius: 30px;
            margin-bottom: 30px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            display: none;
            animation: fadeIn 0.5s ease;
        }
        
        .module.active {
            display: block;
        }
        
        .module::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 8px;
            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
        }
        
        .module-header {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
            gap: 15px;
            position: relative;
        }
        
        .module-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary), var(--purple));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Fredoka One', cursive;
            font-size: 1.8em;
            color: white;
            box-shadow: 0 8px 25px rgba(255,107,107,0.4);
            flex-shrink: 0;
        }
        
        .module-title {
            font-family: 'Fredoka One', cursive;
            font-size: 1.8em;
            color: var(--dark);
            flex: 1;
        }
        
        .module-icon {
            font-size: 3em;
        }
        
        .highlight {
            background: linear-gradient(120deg, var(--accent) 0%, var(--accent) 100%);
            background-repeat: no-repeat;
            background-size: 100% 40%;
            background-position: 0 88%;
            padding: 0 4px;
            font-weight: 800;
        }
        
        /* Cards */
        .content-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 25px 0;
        }
        
        .card {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
            border-radius: 20px;
            padding: 25px;
            transition: all 0.3s ease;
            border: 3px solid transparent;
            cursor: pointer;
        }
        
        .card:hover {
            transform: translateY(-5px);
            border-color: var(--secondary);
            box-shadow: 0 15px 40px rgba(78,205,196,0.3);
        }
        
        .card-icon {
            font-size: 2.5em;
            margin-bottom: 15px;
            display: block;
        }
        
        .card h3 {
            font-family: 'Fredoka One', cursive;
            color: var(--purple);
            margin-bottom: 10px;
            font-size: 1.3em;
        }
        
        /* Curiosidade */
        .fun-fact {
            background: linear-gradient(135deg, var(--accent), #ffd93d);
            border-radius: 20px;
            padding: 25px;
            margin: 25px 0;
            position: relative;
            border-left: 6px solid #ff9500;
        }
        
        .fun-fact::before {
            content: '💡';
            font-size: 2em;
            position: absolute;
            top: -15px;
            left: 20px;
            background: white;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        
        .fun-fact p {
            margin-top: 10px;
            font-weight: 700;
            color: #8b6914;
        }
        
        /* Atividades */
        .activity-box {
            background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
            border-radius: 25px;
            padding: 30px;
            margin-top: 30px;
            border: 3px dashed var(--purple);
        }
        
        .activity-box h3 {
            font-family: 'Fredoka One', cursive;
            color: var(--purple);
            font-size: 1.5em;
            margin-bottom: 20px;
        }
        
        .activity-list {
            list-style: none;
        }
        
        .activity-list li {
            background: white;
            margin: 12px 0;
            padding: 18px 20px 18px 55px;
            border-radius: 15px;
            position: relative;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .activity-list li:hover {
            transform: translateX(10px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }
        
        .activity-list li::before {
            content: attr(data-num);
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            width: 30px;
            height: 30px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Fredoka One', cursive;
            font-weight: bold;
            font-size: 0.9em;
        }
        
        .activity-list li.completed {
            background: #d4edda;
            border-left: 4px solid var(--success);
        }
        
        .activity-list li.completed::after {
            content: '✓';
            position: absolute;
            right: 15px;
            color: var(--success);
            font-weight: bold;
            font-size: 1.2em;
        }
        
        /* Teclado Virtual */
        .keyboard-section {
            margin: 30px 0;
            text-align: center;
        }
        
        .keyboard-demo {
            display: inline-grid;
            grid-template-columns: repeat(10, 1fr);
            gap: 4px;
            padding: 15px;
            background: #2c3e50;
            border-radius: 15px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }
        
        .key {
            aspect-ratio: 1;
            min-width: 30px;
            background: linear-gradient(180deg, #ecf0f1, #bdc3c7);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8em;
            box-shadow: 0 3px 0 #95a5a6, 0 4px 8px rgba(0,0,0,0.2);
            cursor: pointer;
            transition: all 0.1s;
            user-select: none;
            color: #2c3e50;
        }
        
        .key:active {
            transform: translateY(3px);
            box-shadow: 0 0 0 #95a5a6;
        }
        
        .key.special {
            background: linear-gradient(180deg, #3498db, #2980b9);
            color: white;
            box-shadow: 0 3px 0 #1f618d;
        }
        
        .key.space {
            grid-column: span 5;
            aspect-ratio: 5/1;
        }
        
        .keyboard-output {
            margin-top: 20px;
            padding: 20px;
            background: white;
            border-radius: 15px;
            min-height: 60px;
            font-family: 'Courier New', monospace;
            font-size: 1.5em;
            border: 3px solid var(--secondary);
            word-break: break-all;
        }
        
        .btn {
            padding: 10px 25px;
            border: none;
            border-radius: 25px;
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1em;
            margin: 5px;
        }
        
        .btn-primary {
            background: var(--primary);
            color: white;
            box-shadow: 0 5px 15px rgba(255,107,107,0.4);
        }
        
        .btn-secondary {
            background: var(--secondary);
            color: white;
            box-shadow: 0 5px 15px rgba(78,205,196,0.4);
        }
        
        .btn:hover {
            transform: translateY(-2px);
        }
        
        /* Jogo Binário */
        .binary-section {
            text-align: center;
            margin: 30px 0;
            padding: 30px;
            background: linear-gradient(135deg, #667eea20, #764ba220);
            border-radius: 25px;
        }
        
        .binary-game {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            margin: 25px 0;
        }
        
        .binary-card {
            width: 80px;
            height: 110px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            font-family: 'Fredoka One', cursive;
            font-size: 1.8em;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(102,126,234,0.4);
            user-select: none;
        }
        
        .binary-card:hover {
            transform: translateY(-8px);
        }
        
        .binary-card.active {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            transform: scale(1.1);
        }
        
        .binary-card .bit-value {
            font-size: 0.5em;
            opacity: 0.9;
            margin-top: 5px;
        }
        
        .binary-total {
            font-size: 2.5em;
            font-family: 'Fredoka One', cursive;
            color: var(--primary);
            margin: 20px 0;
        }
        
        /* Quiz */
        .quiz-container {
            background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
            border-radius: 25px;
            padding: 30px;
            margin-top: 30px;
            text-align: center;
        }
        
        .quiz-header {
            font-family: 'Fredoka One', cursive;
            font-size: 1.8em;
            color: var(--purple);
            margin-bottom: 25px;
        }
        
        .quiz-question {
            font-size: 1.2em;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 25px;
            padding: 20px;
            background: white;
            border-radius: 15px;
        }
        
        .quiz-options {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
            max-width: 500px;
            margin: 0 auto;
        }
        
        .quiz-btn {
            padding: 18px 25px;
            border: 3px solid transparent;
            border-radius: 15px;
            background: white;
            font-family: 'Nunito', sans-serif;
            font-size: 1.1em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: left;
        }
        
        .quiz-btn:hover:not(.disabled) {
            transform: translateY(-3px);
            border-color: var(--secondary);
        }
        
        .quiz-btn.correct {
            background: var(--success);
            color: white;
        }
        
        .quiz-btn.wrong {
            background: #e74c3c;
            color: white;
        }
        
        .quiz-btn.disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        
        .quiz-feedback {
            margin-top: 25px;
            padding: 20px;
            border-radius: 15px;
            font-weight: 700;
            display: none;
        }
        
        .quiz-feedback.show {
            display: block;
        }
        
        .quiz-feedback.success {
            background: #d4edda;
            color: #155724;
            border: 2px solid var(--success);
        }
        
        .quiz-feedback.error {
            background: #f8d7da;
            color: #721c24;
            border: 2px solid #dc3545;
        }
        
        /* Conquistas */
        .achievements-panel {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            border-radius: 30px;
            padding: 40px 30px;
            margin: 40px 0;
            color: white;
            text-align: center;
        }
        
        .achievements-title {
            font-family: 'Fredoka One', cursive;
            font-size: 2.2em;
            margin-bottom: 10px;
        }
        
        .badges-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin: 30px 0;
        }
        
        .badge {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #ffd700, #ffed4e);
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(255,215,0,0.4);
            transition: all 0.3s ease;
            cursor: pointer;
            border: 4px solid rgba(255,255,255,0.5);
        }
        
        .badge:hover {
            transform: scale(1.15) rotate(10deg);
        }
        
        .badge.locked {
            background: linear-gradient(135deg, #95a5a6, #7f8c8d);
            filter: grayscale(1);
        }
        
        .badge-icon {
            font-size: 2.2em;
        }
        
        .badge-name {
            font-size: 0.65em;
            font-weight: 800;
            text-align: center;
            margin-top: 3px;
            line-height: 1.2;
        }
        
        .certificate-btn {
            margin-top: 20px;
            padding: 15px 40px;
            font-size: 1.2em;
            font-family: 'Fredoka One', cursive;
            background: white;
            color: #f5576c;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }
        
        .certificate-btn:hover:not(:disabled) {
            transform: translateY(-3px) scale(1.05);
        }
        
        .certificate-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        /* Glossário */
        .glossary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin: 25px 0;
        }
        
        .term-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            border-left: 6px solid var(--secondary);
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .term-card:hover {
            transform: translateY(-5px);
            border-left-color: var(--primary);
        }
        
        .term-card h4 {
            color: var(--purple);
            font-family: 'Fredoka One', cursive;
            font-size: 1.2em;
            margin-bottom: 10px;
        }
        
        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        
        .modal.show {
            display: flex;
        }
        
        .modal-content {
            background: white;
            padding: 40px;
            border-radius: 30px;
            max-width: 600px;
            width: 100%;
            text-align: center;
            border: 8px solid gold;
            background: linear-gradient(135deg, #fff9e6 0%, #ffffff 100%);
            animation: fadeIn 0.3s ease;
        }
        
        .modal-close {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 2em;
            cursor: pointer;
            color: #999;
        }
        
        .student-name-input {
            width: 100%;
            padding: 15px;
            font-size: 1.3em;
            border: 3px solid var(--secondary);
            border-radius: 15px;
            text-align: center;
            font-family: 'Nunito', sans-serif;
            margin: 20px 0;
            outline: none;
        }
        
        .student-name-input:focus {
            border-color: var(--primary);
        }
        
        /* Footer */
        footer {
            background: var(--dark);
            color: white;
            text-align: center;
            padding: 40px 20px;
            margin-top: 60px;
        }
        
        .footer-emoji {
            font-size: 3em;
            margin-bottom: 20px;
            display: inline-block;
            animation: wave 2s infinite;
        }
        
        .footer-title {
            font-family: 'Fredoka One', cursive;
            font-size: 1.8em;
            margin-bottom: 15px;
        }
        
        /* Responsivo */
        @media (max-width: 768px) {
            h1 { font-size: 1.6em; }
            .module-title { font-size: 1.4em; }
            .quick-nav { top: 90px; padding: 10px; }
            .nav-btn { padding: 8px 15px; font-size: 0.85em; }
            .keyboard-demo { grid-template-columns: repeat(5, 1fr); }
            .key { min-width: 25px; font-size: 0.7em; }
            .binary-card { width: 70px; height: 95px; font-size: 1.5em; }
        }
        
        .text-center { text-align: center; }
        .mt-20 { margin-top: 20px; }
    </style>
</head>
<body>
    <!-- Shapes de Fundo -->
    <div class="floating-shapes">
        <div class="shape" style="top: 10%; left: 5%; animation-delay: 0s;">💻</div>
        <div class="shape" style="top: 20%; right: 8%; animation-delay: 3s;">🎮</div>
        <div class="shape" style="top: 60%; left: 3%; animation-delay: 6s;">🚀</div>
        <div class="shape" style="bottom: 25%; right: 5%; animation-delay: 9s;">⭐</div>
        <div class="shape" style="top: 40%; left: 95%; animation-delay: 12s;">🎯</div>
    </div>

    <!-- Header -->
    <header>
        <div class="header-content">
            <h1 onclick="showModule(0)">🚀 Aventura Digital</h1>
            <p class="subtitle">Aprendendo Computação de Forma Divertida!</p>
            <div class="progress-container">
                <div class="progress-bar">
                    <div class="progress-fill" id="mainProgress"></div>
                </div>
                <div class="progress-text">Progresso: <span id="progressPercent">0</span>%</div>
            </div>
        </div>
    </header>

    <!-- Navegação -->
