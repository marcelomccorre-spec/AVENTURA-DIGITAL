                    <h3 style="font-family: 'Fredoka One', cursive; font-size: 1.8em; margin-bottom: 15px;">🎓 Certificado de Conclusão</h3>
                    <p style="margin-bottom: 20px;">Parabéns por completar a Aventura Digital!</p>
                    <button class="certificate-btn" id="certBtn" onclick="openCertificate()" disabled>
                        📜 Gerar Certificado
                    </button>
                    <p style="font-size: 0.9em; margin-top: 15px; opacity: 0.9;">
                        Complete pelo menos 15 atividades para desbloquear
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal do Certificado -->
    <div class="modal" id="certModal">
        <div class="modal-content" style="position: relative;">
            <span class="modal-close" onclick="closeModal()">&times;</span>
            <div style="border: 5px double gold; padding: 30px; border-radius: 20px; background: linear-gradient(135deg, #fff9e6, #ffffff);">
                <div style="font-size: 4em; margin-bottom: 20px;">🚀</div>
                <h2 style="font-family: 'Fredoka One', cursive; color: var(--purple); font-size: 2em; margin-bottom: 10px;">
                    Certificado de Conclusão
                </h2>
                <p style="font-size: 1.2em; color: #666; margin-bottom: 20px;">
                    Aventura Digital - Computação para Crianças
                </p>
                <div style="font-size: 1.3em; margin: 30px 0; color: var(--dark);">
                    Certifico que<br>
                    <input type="text" class="student-name-input" id="studentName" placeholder="Digite seu nome aqui" maxlength="30">
                    <br>completou com sucesso<br>
                    <strong> todos os módulos do curso!</strong>
                </div>
                <div style="margin-top: 30px; padding-top: 20px; border-top: 2px solid gold;">
                    <p style="color: #888; font-size: 0.9em;">
                        Data: <span id="currentDate"></span><br>
                        Carga horária: 10 horas
                    </p>
                </div>
                <button class="btn btn-primary" onclick="printCertificate()" style="margin-top: 20px; font-size: 1.1em;">
                    🖨️ Imprimir Certificado
                </button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-emoji">👋</div>
            <h2 class="footer-title">Obrigado por Aprender Conosco!</h2>
            <p class="footer-text">
                A tecnologia é uma ferramenta poderosa.<br>
                Use-a para criar, aprender e tornar o mundo melhor!<br><br>
                <strong>Continue explorando, continue criando! 🚀</strong>
            </p>
            <div class="footer-info">
                <p>Material Didático - Computação Básica para Crianças</p>
                <p>Recomendado para crianças de 7 a 12 anos</p>
            </div>
        </div>
    </footer>

    <script>
        // Estado do usuário
        let currentModule = 0;
        let completedActivities = 0;
        let totalActivities = 20; // Total aproximado de atividades
        let binarySum = 0;
        let keyboardText = '';
        
        // Navegação entre módulos
        function showModule(index) {
            // Esconde todos os módulos
            document.querySelectorAll('.module').forEach(m => m.classList.remove('active'));
            // Mostra o módulo selecionado
            document.getElementById('module-' + index).classList.add('active');
            
            // Atualiza botões de navegação
            document.querySelectorAll('.nav-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === index);
            });
            
            currentModule = index;
            window.scrollTo({ top: 0, behavior: 'smooth' });
            
            // Salva progresso no localStorage
            localStorage.setItem('adventureModule', index);
        }
        
        // Toggle de cards
        function toggleCard(card) {
            card.style.transform = card.style.transform === 'scale(1.05)' ? '' : 'scale(1.05)';
        }
        
        // Atividades
        function toggleActivity(li) {
            li.classList.toggle('completed');
            updateProgress();
            saveProgress();
        }
        
        // Atualiza barra de progresso
        function updateProgress() {
            const completed = document.querySelectorAll('.activity-list li.completed').length;
            completedActivities = completed;
            const percent = Math.min(100, Math.round((completed / 12) * 100)); // 12 atividades mínimas
            
            document.getElementById('mainProgress').style.width = percent + '%';
            document.getElementById('progressPercent').textContent = percent;
            
            // Desbloqueia certificado se >= 75%
            if (percent >= 75) {
                document.getElementById('certBtn').disabled = false;
            }
            
            // Desbloqueia badges conforme progresso
            if (percent >= 20) unlockBadge(1);
            if (percent >= 40) unlockBadge(2);
            if (percent >= 60) unlockBadge(3);
            if (percent >= 80) unlockBadge(4);
            if (percent >= 90) unlockBadge(5);
        }
        
        // Sistema de Badges
        function unlockBadge(num) {
            const badge = document.getElementById('badge' + num);
            if (badge && badge.classList.contains('locked')) {
                badge.classList.remove('locked');
                badge.style.animation = 'bounce 0.5s ease';
            }
        }
        
        // Teclado Virtual
        document.querySelectorAll('.key').forEach(key => {
            key.addEventListener('click', function() {
                const char = this.getAttribute('data-key');
                
                if (char === 'Backspace') {
                    keyboardText = keyboardText.slice(0, -1);
                } else if (char === 'Shift') {
                    // Toggle maiúsculas (simplificado)
                } else {
                    keyboardText += char;
                }
                
                document.getElementById('keyboardOutput').textContent = keyboardText || 'Clique nas teclas acima...';
                this.style.transform = 'translateY(3px)';
                setTimeout(() => this.style.transform = '', 100);
            });
        });
        
        function clearKeyboard() {
            keyboardText = '';
            document.getElementById('keyboardOutput').textContent = 'Clique nas teclas acima...';
        }
        
        function checkKeyboardTask() {
            if (keyboardText.length > 0) {
                alert('🎉 Parabéns! Você digitou: ' + keyboardText);
                // Marca atividade como completa automaticamente
                const activities = document.querySelectorAll('#module-1 .activity-list li');
                if (activities[2]) activities[2].classList.add('completed');
                updateProgress();
            } else {
                alert('Digite algo primeiro!');
            }
        }
        
        // Jogo Binário
        function toggleBinary(card, value) {
            const span = card.querySelector('span:first-child');
            const isActive = card.classList.contains('active');
            
            if (isActive) {
                card.classList.remove('active');
                span.textContent = '0';
                binarySum -= value;
            } else {
                card.classList.add('active');
                span.textContent = '1';
                binarySum += value;
            }
            
            document.getElementById('binaryResult').textContent = binarySum;
            
            // Verifica se acertou o desafio (número 5)
            if (binarySum === 5) {
                setTimeout(() => {
                    alert('🎉 Incrível! Você representou o número 5 em binário (0101)!');
                }, 300);
            }
        }
        
        // Quiz
        function checkAnswer(btn, isCorrect) {
            const feedback = document.getElementById('quizFeedback');
            const buttons = document.querySelectorAll('.quiz-btn');
            
            buttons.forEach(b => {
                b.disabled = true;
                b.classList.add('disabled');
            });
            
            if (isCorrect) {
                btn.classList.add('correct');
                feedback.innerHTML = '🎉 Correto! Você é um verdadeiro Herói Digital!<br><small>Nunca compartilhe senhas, mesmo com "amigos" online!</small>';
                feedback.className = 'quiz-feedback show success';
                unlockBadge(5);
                
                // Marca atividade como completa
                const activities = document.querySelectorAll('#module-5 .activity-list li');
                if (activities[2]) activities[2].classList.add('completed');
                updateProgress();
            } else {
                btn.classList.add('wrong');
                feedback.innerHTML = '❌ Ops! Essa não é a resposta certa.<br><small>Senhas são secretas pessoais, como o código do seu cofrinho!</small>';
                feedback.className = 'quiz-feedback show error';
            }
        }
        
        // Certificado
        function openCertificate() {
            document.getElementById('currentDate').textContent = new Date().toLocaleDateString('pt-BR');
            document.getElementById('certModal').classList.add('show');
        }
        
        function closeModal() {
            document.getElementById('certModal').classList.remove('show');
        }
        
        function printCertificate() {
            const name = document.getElementById('studentName').value;
            if (!name.trim()) {
                alert('Por favor, digite seu nome!');
                return;
            }
            window.print();
        }
        
        // Salvar e Carregar Progresso
        function saveProgress() {
            const completed = [];
            document.querySelectorAll('.activity-list li').forEach((li, index) => {
                if (li.classList.contains('completed')) {
                    completed.push(index);
                }
            });
            localStorage.setItem('adventureProgress', JSON.stringify(completed));
        }
        
        function loadProgress() {
            const saved = localStorage.getItem('adventureProgress');
            const savedModule = localStorage.getItem('adventureModule');
            
            if (saved) {
                const completed = JSON.parse(saved);
                document.querySelectorAll('.activity-list li').forEach((li, index) => {
                    if (completed.includes(index)) {
                        li.classList.add('completed');
                    }
                });
            }
            
            if (savedModule) {
                showModule(parseInt(savedModule));
            }
            
            updateProgress();
        }
        
        // Fechar modal ao clicar fora
        window.onclick = function(event) {
            const modal = document.getElementById('certModal');
            if (event.target === modal) {
                closeModal();
            }
        }
        
        // Inicialização
        window.onload = function() {
            loadProgress();
            
            // Efeito de digitação no título
            const title = document.querySelector('h1');
            title.addEventListener('mouseenter', function() {
                this.style.transform = 'scale(1.05)';
            });
            title.addEventListener('mouseleave', function() {
                this.style.transform = '';
            });
        };
        
        // Atalhos de teclado
        document.addEventListener('keydown', function(e) {
            // Navegação com setas
            if (e.key === 'ArrowRight' && currentModule < 6) {
                showModule(currentModule + 1);
            } else if (e.key === 'ArrowLeft' && currentModule > 0) {
                showModule(currentModule - 1);
            }
        });
    </script>
</body>
</html>
